{
  "discord": {
    "respond_to_bots": false,
    "max_history_messages": 20,
    "conversation_window_seconds": 10,
    "reply_debounce_seconds": 2.5,
    "presence": {
      "enabled": true,
      "type": "streaming",
      "name": "Helping YOU out",
      "url": "https://rionnag.net/",
      "state": "Used 0 tokens this session",
      "details": null,
      "status": "online",
      "token_usage_enabled": true,
      "token_usage_name_template": "Helping YOU out",
      "token_usage_state_template": "Used {total_tokens:,} tokens this session",
      "token_usage_details_template": null
    }
  },
  "memory": {
    "enabled": true,
    "user_directory": "memories/users",
    "guild_directory": "memories/guilds",
    "dm_history_db_path": "memories/dm_history.sqlite3",
    "max_user_chars_in_prompt": 6000,
    "max_guild_chars_in_prompt": 6000
  },
  "passive_guild_memory": {
    "enabled": true,
    "db_path": "memories/guild_passive.sqlite3",
    "primary_model": "nvidia/nemotron-3-super-120b-a12b:free",
    "fallback_model": "openrouter/free",
    "effective_context_limit_tokens": 262144,
    "flush_ratio": 0.8,
    "max_output_tokens": 1800,
    "temperature": 0.2,
    "poll_interval_seconds": 15,
    "enabled_guild_ids": null
  },
  "openrouter": {
    "base_url": "https://openrouter.ai/api/v1",
    "default_model": "deepseek/deepseek-v4-flash",
    "app_name": "DiscoAssistant",
    "site_url": null
  },
  "tool_policy": {
    "allow_model_tool_calls": true,
    "max_calls_per_turn": 6,
    "timeout_seconds": 30,
    "registry": [
      {
        "name": "read_channel_messages",
        "description": "Read recent messages from the current Discord channel or another by id.",
        "enabled": true
      },
      {
        "name": "lookup_user",
        "description": "Get profile details for a Discord user (defaults to current chatter).",
        "enabled": true
      },
      {
        "name": "remember",
        "description": "Save a durable note. scope=user or scope=server. Owner-only for scope=server.",
        "enabled": true
      },
      {
        "name": "replace_in_memory",
        "description": "Owner-only. Substring-replace existing memory. scope=user or server.",
        "enabled": true
      },
      {
        "name": "read_user_memory",
        "description": "Owner-only. Read the memory file for a specific Discord user id.",
        "enabled": true
      },
      {
        "name": "server_log",
        "description": "Owner-only. Manage passive server-memory queue. action=preview|flush|cancel.",
        "enabled": true
      },
      {
        "name": "send_dm",
        "description": "Send a direct message. Non-owner may only DM the owner; owner may DM anyone.",
        "enabled": true
      }
    ]
  },
  "prompts": {},
  "agents": {
    "owner": {
      "name": "Owner",
      "description": "The personality used when replying to the owner of the account.",
      "system_prompt": "",
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.35,
      "max_output_tokens": 180,
      "tools": [
        "read_channel_messages",
        "lookup_user",
        "remember",
        "replace_in_memory",
        "read_user_memory",
        "server_log",
        "send_dm"
      ],
      "handoff_targets": []
    },
    "public": {
      "name": "Public",
      "description": "The personality used when replying to anyone other than the owner.",
      "system_prompt": "",
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.4,
      "max_output_tokens": 180,
      "tools": [
        "read_channel_messages",
        "lookup_user"
      ],
      "handoff_targets": []
    }
  }
}
